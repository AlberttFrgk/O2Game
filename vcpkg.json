{
  "name": "o2game",
  "version": "1.0.0",
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    {
      "name": "sdl2",
      "features": [ "vulkan" ]
    },
    {
      "name": "sdl2-image",
      "features": [ "libjpeg-turbo" ]
    },
    {
      "name": "glm"
    },
    {
      "name": "freetype",
      "default-features": false,
      "features": [ "bzip2", "png", "zlib" ]
    },
    {
      "name": "vulkan"
    },
    {
      "name": "libpng"
    },
    {
      "name": "sqlite3"
    },
    {
      "name": "libiconv"
    },
    {
      "name": "sol2"
    },
    {
      "name": "lua"
    },
    {
      "name": "glslang",
      "features": ["tools"]
    },
    {
      "name": "ffmpeg"
    }
  ]
}